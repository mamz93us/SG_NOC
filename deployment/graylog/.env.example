# ─────────────────────────────────────────────────────────────────────────
# Copy to .env (in the same directory) and fill in values. NOT committed.
# ─────────────────────────────────────────────────────────────────────────

# 96+ char random string. Generate with:
#   pwgen -N 1 -s 96
# (or)
#   openssl rand -base64 72 | tr -d '\n'
GRAYLOG_PASSWORD_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# SHA-256 of your chosen admin password. Generate with:
#   echo -n "MyAdminPassword" | sha256sum | awk '{print $1}'
GRAYLOG_ROOT_PASSWORD_SHA2=REPLACE_WITH_SHA256_OF_PASSWORD

# Public URL users will browse to. Trailing slash is required.
GRAYLOG_HTTP_EXTERNAL_URI=https://logs.samirgroup.net/
