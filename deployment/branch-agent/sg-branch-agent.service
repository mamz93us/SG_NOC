[Unit]
Description=SG Branch Agent (logs, device monitoring, DDNS)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sgagent
Group=sgagent
ExecStart=/usr/local/bin/sg-branch-agent
Restart=always
RestartSec=5
# Allow the non-root agent to bind syslog :514.
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/sg-branch-agent /etc/sg-branch-agent

[Install]
WantedBy=multi-user.target
