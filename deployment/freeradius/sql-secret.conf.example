# =============================================================================
# FreeRADIUS → MySQL credentials
# =============================================================================
# Deploy as /etc/freeradius/3.0/mods-config/sql/secret.conf
# Permissions:
#   sudo chown root:freerad /etc/freeradius/3.0/mods-config/sql/secret.conf
#   sudo chmod 640         /etc/freeradius/3.0/mods-config/sql/secret.conf
#
# The password must match the one assigned to the `freeradius`@`localhost`
# MySQL user in deployment/freeradius/setup.sql.
# =============================================================================

password = "REPLACE_ME_WITH_A_LONG_RANDOM_STRING"
