# ─────────────────────────────────────────────────────────────────────────
# /etc/sg-noc-branch.env — per-VM environment file (NOT committed to git).
#
# Copy this template to /etc/sg-noc-branch.env on each branch VM, fill in
# the values, then run install.sh. The installer reads this file and uses
# it to render config templates for rsyslog, MariaDB, the ingester, and
# the API.
# ─────────────────────────────────────────────────────────────────────────

# Three-letter code identifying this branch. Used as MariaDB database name
# suffix and as a tag on every log row. Lowercase, no spaces.
BRANCH_ID=jed

# Human-readable name shown in the NOC UI dropdown.
BRANCH_NAME="Jeddah"

# IANA timezone — controls how rsyslog timestamps and partition rollover
# interpret "today". Use the office's local timezone, not UTC.
TIMEZONE=Asia/Riyadh

# How many days of logs to retain. Partition older than this is dropped
# nightly by sg-noc-partition-rotate.timer.
RETENTION_DAYS=60

# MariaDB credentials. Generated automatically by install.sh on first run
# if you leave them blank — paste them somewhere safe afterwards.
DB_NAME=sg_noc_branch
DB_USER=sg_noc
DB_PASSWORD=

# Bearer token the NOC must send in Authorization headers when querying
# this branch's API. Generated automatically by install.sh on first run.
# Add to NOC's .env as BRANCH_API_TOKEN_<BRANCHID> (uppercase).
API_TOKEN=

# CIDR of the NOC's tunnel-side IP that's allowed to query the API.
# Other source IPs get 403 from nginx. Use 0.0.0.0/0 only for testing.
NOC_ALLOWED_CIDR=10.0.0.0/8

# Optional: forward filtered/critical messages to a central Graylog too,
# so existing alert pipelines keep working. Leave blank to disable.
NOC_GRAYLOG_HOST=
NOC_GRAYLOG_PORT=1514

# ─── SNMP / metrics (used by Telegraf + sg-noc-snmp-sync) ──────────────
# NOC URL — used by snmp-sync.php and nmap-discover.php to call back.
NOC_URL=https://noc.samirgroup.net

# VictoriaMetrics remote_write endpoint at the NOC. nginx proxies this
# to the loopback VM container; basic auth is enforced at nginx.
NOC_METRICS_URL=https://metrics.samirgroup.net/api/v1/write
NOC_METRICS_USER=sg-noc
NOC_METRICS_PASSWORD=

# nmap discovery scope. Leave SCAN_SUBNETS blank to auto-detect from
# this VM's local interfaces (capped at /24 each). Otherwise space-
# separated CIDRs:  SCAN_SUBNETS="10.3.0.0/24 10.3.1.0/24 10.3.88.0/24"
SCAN_SUBNETS=
SCAN_SNMP_COMMUNITY=public
