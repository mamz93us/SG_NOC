# Copy to .env on the VPS and fill in real values.
# Do NOT commit the real .env.

# Public IPv4 of this VPS (run: curl -s ifconfig.me).
# MUST be the exact public IP — WebRTC NAT1TO1 will not work otherwise.
VPS_PUBLIC_IP=

# Password for unprivileged Neko users logging into the smoke-test Chromium.
NEKO_USER_PASSWORD=

# Password for admin users (can kick/ban others inside the Neko UI).
NEKO_ADMIN_PASSWORD=
