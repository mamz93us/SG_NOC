# Amazon SES SMTP credentials for Postfix.
#
# The REAL file lives at /etc/postfix/sasl_passwd (mode 600, git-ignored) and is
# generated by setup.sh — you normally never write it by hand.
#
# Format:  [smtp-endpoint]:port  USERNAME:PASSWORD
#   USERNAME = AWS_ACCESS_KEY_ID  (unchanged)
#   PASSWORD = SES SMTP password derived from AWS_SECRET_ACCESS_KEY via
#              ses-smtp-password.sh (NOT the raw AWS secret key)
#
# After editing the real file:  postmap /etc/postfix/sasl_passwd && postfix reload

[email-smtp.us-east-1.amazonaws.com]:587 AKIAEXAMPLEACCESSKEY:BLBM_derived_ses_smtp_password
