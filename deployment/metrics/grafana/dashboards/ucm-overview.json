{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["sg-noc", "grandstream", "ucm", "voip"],
  "templating": {
    "list": [
      {
        "name": "branch",
        "label": "Branch",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "victoriametrics"},
        "query": "label_values(snmp_concurrent_calls{device_type=\"grandstream_ucm\"}, branch)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {"text": ["All"], "value": ["$__all"]},
        "sort": 1
      },
      {
        "name": "device",
        "label": "UCM",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "victoriametrics"},
        "query": "label_values(snmp_concurrent_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\"}, device_name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {"text": ["All"], "value": ["$__all"]},
        "sort": 1
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Grandstream UCM — Overview",
  "uid": "sg-noc-ucm-overview",
  "version": 1,
  "panels": [
    {
      "id": 1, "type": "stat", "title": "UCMs reporting",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "count(snmp_concurrent_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "unit": "short"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "justifyMode": "center"}
    },
    {
      "id": 2, "type": "stat", "title": "Concurrent calls (now)",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "sum(snmp_concurrent_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "blue"}, "unit": "short"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "justifyMode": "center"}
    },
    {
      "id": 3, "type": "stat", "title": "Calls per minute (last 5m)",
      "description": "rate(snmp_total_calls) × 60 — rolling rate over 5 min.",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "60 * sum(rate(snmp_total_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}[5m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "purple"}, "unit": "cpm", "decimals": 1}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "justifyMode": "center"}
    },
    {
      "id": 4, "type": "stat", "title": "Failed-call ratio (5m)",
      "description": "(failed + busy + no_answer) / total. > 30 % suggests trunk or routing issues.",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "100 * (sum(rate(snmp_failed_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}[5m])) + sum(rate(snmp_busy_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}[5m])) + sum(rate(snmp_no_answer_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}[5m]))) / (sum(rate(snmp_total_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}[5m])) > 0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 15}, {"color": "red", "value": 30}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "justifyMode": "center"}
    },

    {
      "id": 5, "type": "table", "title": "UCM inventory",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 5},
      "targets": [
        {"expr": "snmp_concurrent_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}",   "refId": "A", "format": "table", "instant": true},
        {"expr": "snmp_cpu_usage_pct{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}",     "refId": "B", "format": "table", "instant": true},
        {"expr": "snmp_memory_usage_pct{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}",  "refId": "C", "format": "table", "instant": true},
        {"expr": "snmp_disk_usage_pct{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}",    "refId": "D", "format": "table", "instant": true}
      ],
      "transformations": [
        {"id": "joinByField", "options": {"byField": "device_name", "mode": "outer"}},
        {"id": "organize", "options": {
          "excludeByName": {
            "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true,
            "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true,
            "agent_host 1": true, "agent_host 2": true, "agent_host 3": true, "agent_host 4": true,
            "device_type 1": true, "device_type 2": true, "device_type 3": true, "device_type 4": true,
            "host 1": true, "host 2": true, "host 3": true, "host 4": true,
            "instance 1": true, "instance 2": true, "instance 3": true, "instance 4": true,
            "job 1": true, "job 2": true, "job 3": true, "job 4": true,
            "branch 2": true, "branch 3": true, "branch 4": true,
            "product_type 2": true, "product_type 3": true, "product_type 4": true,
            "fw_version 2": true, "fw_version 3": true, "fw_version 4": true,
            "hw_version 2": true, "hw_version 3": true, "hw_version 4": true,
            "serial 2": true, "serial 3": true, "serial 4": true,
            "sys_name 2": true, "sys_name 3": true, "sys_name 4": true
          },
          "renameByName": {
            "branch 1": "Branch", "device_name": "UCM", "sys_name 1": "Hostname",
            "product_type 1": "Model", "fw_version 1": "Firmware", "serial 1": "Serial",
            "Value #A": "Concurrent", "Value #B": "CPU %", "Value #C": "Memory %", "Value #D": "Disk %"
          },
          "indexByName": {
            "branch 1": 0, "device_name": 1, "product_type 1": 2, "fw_version 1": 3, "serial 1": 4,
            "Value #A": 5, "Value #B": 6, "Value #C": 7, "Value #D": 8
          }
        }}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto"}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "CPU %"},    "properties": [{"id": "unit", "value": "percent"}, {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}]},
          {"matcher": {"id": "byName", "options": "Memory %"}, "properties": [{"id": "unit", "value": "percent"}, {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 75}, {"color": "red", "value": 90}]}}]},
          {"matcher": {"id": "byName", "options": "Disk %"},   "properties": [{"id": "unit", "value": "percent"}, {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 80}, {"color": "red", "value": 95}]}}]}
        ]
      }
    },

    {
      "id": 6, "type": "gauge", "title": "CPU usage",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"x": 0, "y": 9, "w": 8, "h": 6},
      "targets": [{"expr": "snmp_cpu_usage_pct{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}", "refId": "A", "legendFormat": "{{device_name}}"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}},
      "options": {"showThresholdLabels": false, "showThresholdMarkers": true}
    },
    {
      "id": 7, "type": "gauge", "title": "Memory usage",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"x": 8, "y": 9, "w": 8, "h": 6},
      "targets": [{"expr": "snmp_memory_usage_pct{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}", "refId": "A", "legendFormat": "{{device_name}}"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 75}, {"color": "red", "value": 90}]}}},
      "options": {"showThresholdLabels": false, "showThresholdMarkers": true}
    },
    {
      "id": 8, "type": "gauge", "title": "Disk usage",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"x": 16, "y": 9, "w": 8, "h": 6},
      "targets": [{"expr": "snmp_disk_usage_pct{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}", "refId": "A", "legendFormat": "{{device_name}}"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 80}, {"color": "red", "value": 95}]}}},
      "options": {"showThresholdLabels": false, "showThresholdMarkers": true}
    },

    {
      "id": 9, "type": "timeseries", "title": "Concurrent calls over time",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"x": 0, "y": 15, "w": 12, "h": 8},
      "targets": [{"expr": "snmp_concurrent_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}", "refId": "A", "legendFormat": "{{branch}} · {{device_name}}"}],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth"}}},
      "options": {"legend": {"displayMode": "table", "calcs": ["lastNotNull", "max", "mean"], "placement": "bottom"}}
    },
    {
      "id": 10, "type": "timeseries", "title": "Calls per minute by direction",
      "description": "rate(...) × 60 over 5 min for inbound / outbound / internal counters.",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"x": 12, "y": 15, "w": 12, "h": 8},
      "targets": [
        {"expr": "60 * rate(snmp_inbound_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}[5m])",  "refId": "A", "legendFormat": "inbound · {{device_name}}"},
        {"expr": "60 * rate(snmp_outbound_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}[5m])", "refId": "B", "legendFormat": "outbound · {{device_name}}"},
        {"expr": "60 * rate(snmp_internal_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}[5m])", "refId": "C", "legendFormat": "internal · {{device_name}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "cpm", "custom": {"drawStyle": "line", "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "calcs": ["mean", "max"], "placement": "bottom"}}
    },

    {
      "id": 11, "type": "timeseries", "title": "Call outcomes per minute",
      "description": "answered / failed / busy / no-answer rates.",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"x": 0, "y": 23, "w": 24, "h": 8},
      "targets": [
        {"expr": "60 * rate(snmp_answered_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}[5m])",   "refId": "A", "legendFormat": "answered · {{device_name}}"},
        {"expr": "60 * rate(snmp_failed_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}[5m])",     "refId": "B", "legendFormat": "failed · {{device_name}}"},
        {"expr": "60 * rate(snmp_busy_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}[5m])",       "refId": "C", "legendFormat": "busy · {{device_name}}"},
        {"expr": "60 * rate(snmp_no_answer_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}[5m])",  "refId": "D", "legendFormat": "no-answer · {{device_name}}"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "cpm", "custom": {"drawStyle": "line", "fillOpacity": 10}},
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "answered.*"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
          {"matcher": {"id": "byRegexp", "options": "failed.*"},   "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]},
          {"matcher": {"id": "byRegexp", "options": "busy.*"},     "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
          {"matcher": {"id": "byRegexp", "options": "no-answer.*"},"properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "table", "calcs": ["mean", "max", "sum"], "placement": "bottom"}}
    },

    {
      "id": 12, "type": "timeseries", "title": "Cumulative calls (since UCM boot)",
      "description": "Raw monotonic counters from sCdr — useful for long-term trend, resets on reboot.",
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "gridPos": {"x": 0, "y": 31, "w": 24, "h": 7},
      "targets": [
        {"expr": "snmp_total_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}",     "refId": "A", "legendFormat": "total · {{device_name}}"},
        {"expr": "snmp_inbound_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}",   "refId": "B", "legendFormat": "inbound · {{device_name}}"},
        {"expr": "snmp_outbound_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}",  "refId": "C", "legendFormat": "outbound · {{device_name}}"},
        {"expr": "snmp_answered_calls{device_type=\"grandstream_ucm\",branch=~\"$branch\",device_name=~\"$device\"}",  "refId": "D", "legendFormat": "answered · {{device_name}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"drawStyle": "line", "fillOpacity": 0, "lineWidth": 1}}},
      "options": {"legend": {"displayMode": "table", "calcs": ["lastNotNull"], "placement": "bottom"}}
    }
  ]
}
