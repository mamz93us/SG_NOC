# ─────────────────────────────────────────────────────────────────────────
# /opt/sg-noc/deployment/metrics/.env  (NOT in git)
# Copy this template → .env, fill in, then `docker compose up -d`.
# ─────────────────────────────────────────────────────────────────────────

# VictoriaMetrics HTTP basic auth — Telegraf at every branch will use these
# credentials in its remote_write config. Keep them secret. Generate fresh:
#   openssl rand -hex 24
VM_AUTH_USER=sg-noc
VM_AUTH_PASSWORD=

# Grafana initial admin user. Change the password after first login.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Public URL Grafana lives at. nginx proxies this to 127.0.0.1:3000.
GRAFANA_ROOT_URL=https://metrics.samirgroup.net/

# IPsec tunnel-side IP of THIS NOC — branches push remote_write to
# this IP:8428 directly (skipping nginx + TLS, since the tunnel
# encrypts). Leave blank to keep VictoriaMetrics loopback-only.
VM_TUNNEL_IP=172.22.0.4
