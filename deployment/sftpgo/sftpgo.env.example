# Copy to /etc/sftpgo/sftpgo.env (root:root, chmod 600) and fill in. The systemd
# unit loads it via EnvironmentFile=. NEVER commit the real file.
#
# SFTPGo reads nested config keys from SFTPGO_<SECTION>__<KEY> env vars (double
# underscore = nesting), which is how we keep secrets out of the committed sftpgo.json.

# MySQL password for the 'sftpgo'@'localhost' user created by setup.sql.
SFTPGO_DATA_PROVIDER__PASSWORD=REPLACE_ME

# Bootstrap admin for the SFTPGo web UI (http://127.0.0.1:8080) created on first
# start. Log in once via an SSH tunnel, then CHANGE it in the UI.
SFTPGO_DEFAULT_ADMIN_USERNAME=sgnoc-admin
SFTPGO_DEFAULT_ADMIN_PASSWORD=REPLACE_ME_STRONG

# Only for FTPS behind NAT: the PUBLIC IP devices reach, so PASV advertises a
# routable address. Leave commented on a directly-addressable host.
# SFTPGO_FTPD__BINDINGS__0__FORCE_PASSIVE_IP=203.0.113.10
