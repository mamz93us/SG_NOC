# ─────────────────────────────────────────────────────────────────────────
# SG_NOC syslog secret config — DO NOT commit your real copy.
#
# Copy this file to /etc/rsyslog.d/90-sg-noc-syslog-secret.conf,
# fill in the password, and chmod it 600 root:root.
#
# Database/user are created by deployment/rsyslog/setup.sql.
# ─────────────────────────────────────────────────────────────────────────

# Use ommysql with the credentials below. Wrapped as a ruleset call so
# the main config can `call sgNocSyslogAction` without exposing creds.
ruleset(name="sgNocSyslogAction") {
    action(
        type="ommysql"
        server="127.0.0.1"
        serverport="3306"
        db="sg_noc"
        uid="rsyslog"
        pwd="REPLACE_ME"
        template="sgNocSyslogInsert"

        # Buffer & retry — keep messages if MySQL momentarily restarts.
        queue.type="LinkedList"
        queue.filename="sgnoc_syslog_q"
        queue.maxdiskspace="500m"
        queue.saveonshutdown="on"
        action.resumeRetryCount="-1"
    )
}
