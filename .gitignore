*.log
.env
.env.example
.DS_Store
.env.backup
.env.production

# Deployment templates (per-service .env.example) ARE tracked, so the
# repo carries the expected secret-set for each docker-compose stack.
# Actual .env files in those dirs remain ignored by the rules above.
!deployment/**/.env.example
.phpactor.json
.phpunit.result.cache
/.fleet
/.idea
/.nova
/.phpunit.cache
/.vscode
/.zed
/auth.json
/node_modules
/public/build
/public/hot
/public/storage
/storage/*.key
/storage/pail
/vendor
Homestead.json
Homestead.yaml
Thumbs.db
